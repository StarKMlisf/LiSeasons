        temperaturePage.put("note", loadGuiItem(guiFile, "calendar.temperature-page.note", true, 31, Material.BOOKSHELF, null, null, null, "<yellow>节气提示</yellow>", List.of("<gray>当前节气：<white><term></white></gray>")));

