    private CalendarConfig.FrameConfig loadFrameConfig(FileConfiguration guiFile) {
        Map<Season, CalendarConfig.FrameSeasonConfig> seasons = new EnumMap<>(Season.class);
        seasons.put(Season.SPRING, loadFrameSeason(guiFile, "spring", Material.BIRCH_PLANKS, Material.PINK_PETALS, Material.GREEN_STAINED_GLASS_PANE));
        seasons.put(Season.SUMMER, loadFrameSeason(guiFile, "summer", Material.JUNGLE_PLANKS, Material.SUNFLOWER, Material.ORANGE_STAINED_GLASS_PANE));
        seasons.put(Season.AUTUMN, loadFrameSeason(guiFile, "autumn", Material.ACACIA_PLANKS, Material.PUMPKIN, Material.BROWN_STAINED_GLASS_PANE));
        seasons.put(Season.WINTER, loadFrameSeason(guiFile, "winter", Material.SPRUCE_PLANKS, Material.SNOW_BLOCK, Material.BLUE_STAINED_GLASS_PANE));
        return new CalendarConfig.FrameConfig(
                guiFile.getBoolean("calendar.season-frame.enabled", guiFile.getBoolean("calendar.season-frame", true)),
                loadIntegerList(guiFile, "calendar.season-frame.frame-slots", List.of(0, 1, 2, 3, 5, 6, 7, 8, 9, 17, 18, 26, 27, 35, 36, 44, 47, 53)),
                loadIntegerList(guiFile, "calendar.season-frame.corner-slots", List.of(0, 8, 36, 44)),
                loadIntegerList(guiFile, "calendar.season-frame.accent-slots", List.of(10, 11, 12, 14, 15, 16, 28, 29, 30, 32, 33, 34)),
                seasons
        );
    }

    private CalendarConfig.FrameSeasonConfig loadFrameSeason(FileConfiguration guiFile, String season, Material frame, Material corner, Material accent) {
        String path = "calendar.season-frame.seasons." + season;
        return new CalendarConfig.FrameSeasonConfig(
                loadMaterial(guiFile.getString(path + ".frame-material"), frame),
                loadMaterial(guiFile.getString(path + ".corner-material"), corner),
                loadMaterial(guiFile.getString(path + ".accent-material"), accent)
        );
    }

    private CalendarConfig.GuiItemConfig loadGuiItem(FileConfiguration guiFile, String path, boolean defaultEnabled, int defaultSlot, Material defaultMaterial, Material defaultActiveMaterial, Material defaultColdMaterial, Material defaultHotMaterial, String defaultName, List<String> defaultLore) {
        return new CalendarConfig.GuiItemConfig(
                guiFile.getBoolean(path + ".enabled", defaultEnabled),
                normalizeSlot(guiFile.getInt(path + ".slot", defaultSlot), defaultSlot),
                loadMaterial(guiFile.getString(path + ".material"), defaultMaterial),
                loadOptionalMaterial(guiFile.getString(path + ".active-material"), defaultActiveMaterial),
                loadOptionalMaterial(guiFile.getString(path + ".cold-material"), defaultColdMaterial),
                loadOptionalMaterial(guiFile.getString(path + ".hot-material"), defaultHotMaterial),
                guiFile.getString(path + ".name", defaultName),
                stringList(guiFile, path + ".lore", defaultLore)
        );
    }

    private List<Integer> loadIntegerList(FileConfiguration guiFile, String path, List<Integer> defaults) {
        List<Integer> values = guiFile.getIntegerList(path);
        if (values.isEmpty()) {
            return defaults;
        }
        return values.stream()
                .filter(value -> value >= 0 && value < 54)
                .distinct()
                .toList();
    }

    private List<String> stringList(FileConfiguration guiFile, String path, List<String> defaults) {
        List<String> values = guiFile.getStringList(path);
        return values.isEmpty() ? defaults : values;
    }

    private int normalizeSlot(int value, int fallback) {
        if (value < 0 || value >= 54) {
            return fallback;
        }
        return value;
    }

    private Material loadMaterial(String raw, Material fallback) {
        Material material = loadOptionalMaterial(raw, fallback);
        return material == null ? fallback : material;
    }

    private Material loadOptionalMaterial(String raw, Material fallback) {
        if (raw == null || raw.isBlank()) {
            return fallback;
        }
        Material material = Material.matchMaterial(raw.trim());
        if (material == null) {
            this.plugin.getLogger().warning("Invalid gui.yml material '" + raw + "', fallback to " + (fallback == null ? "empty" : fallback.name()));
            return fallback;
        }
        return material;
    }

    private TemperatureConfig loadTemperatureConfig() {
        File file = new File(this.plugin.getDataFolder(), "temperature.yml");
        FileConfiguration temperatureFile = YamlConfiguration.loadConfiguration(file);

        Map<Season, Double> seasonBaseTemperatures = new EnumMap<>(Season.class);
        seasonBaseTemperatures.put(Season.SPRING, temperatureFile.getDouble("season-base-temperature.spring", 16.0D));
        seasonBaseTemperatures.put(Season.SUMMER, temperatureFile.getDouble("season-base-temperature.summer", 26.0D));
        seasonBaseTemperatures.put(Season.AUTUMN, temperatureFile.getDouble("season-base-temperature.autumn", 18.0D));
        seasonBaseTemperatures.put(Season.WINTER, temperatureFile.getDouble("season-base-temperature.winter", 2.0D));
        Map<Season, TemperatureRangeConfig> seasonBaseRanges = loadSeasonBaseRanges(temperatureFile);
        Map<String, Double> solarTermModifiers = loadDoubleSection(temperatureFile, "solar-term-modifier");
        solarTermModifiers.remove("enable");

        Map<String, Double> biomeOverrides = loadDoubleSection(temperatureFile, "biome-overrides");
        Map<String, Double> armorWarmth = loadDoubleSection(temperatureFile, "armor");
        armorWarmth.remove("leather-disabled-above");
        Map<String, Double> heldItemTemperatureModifiers = loadDoubleSection(temperatureFile, "items.held");

        TemperatureConditionConfig conditionConfig = new TemperatureConditionConfig(
                temperatureFile.getDouble("condition.shade", -1.0D),
                temperatureFile.getDouble("condition.night", -2.0D),
                temperatureFile.getDouble("condition.night-min", temperatureFile.getDouble("condition.night", -2.0D)),
                temperatureFile.getDouble("condition.day-max", 2.0D),
                temperatureFile.getDouble("condition.rain", -2.5D),
                temperatureFile.getDouble("condition.thunder", -4.0D),
                temperatureFile.getDouble("condition.underground", 1.5D),
                temperatureFile.getDouble("condition.high-altitude-start-y", 120.0D),
                temperatureFile.getDouble("condition.high-altitude", -3.0D),
                temperatureFile.getDouble("condition.armor-per-piece", 1.0D),
                temperatureFile.getDouble("condition.held-torch", 1.0D),
                temperatureFile.getDouble("condition.held-soul-torch", -2.0D),
                temperatureFile.getDouble("condition.held-lava-bucket", 5.0D),
                temperatureFile.getDouble("condition.nearby-fire", 4.0D),
                temperatureFile.getDouble("condition.nearby-soul-fire", -8.0D),
                temperatureFile.getDouble("condition.nearby-campfire", 6.0D),
                temperatureFile.getDouble("condition.nearby-soul-campfire", -6.0D),
                temperatureFile.getDouble("condition.nearby-lava", 8.0D),
                temperatureFile.getDouble("condition.nearby-ice", -3.0D),
                temperatureFile.getDouble("condition.nearby-packed-ice", -4.0D),
                temperatureFile.getDouble("condition.nearby-blue-ice", -8.0D),
                Math.max(1, temperatureFile.getInt("condition.nearby-heat-range", 3)),
                temperatureFile.getDouble("condition.water-default", -4.0D),
                temperatureFile.getDouble("condition.water-winter", -10.0D),
                temperatureFile.getDouble("condition.tropical-summer-day", 4.0D)
        );

        List<String> tropicalBiomes = temperatureFile.getStringList("tropical-biomes");

        List<TemperatureEventConfig> events = new java.util.ArrayList<>();
        ConfigurationSection eventSection = temperatureFile.getConfigurationSection("temperatureEvents");
        if (eventSection != null) {
            for (String key : eventSection.getKeys(false)) {
                String basePath = "temperatureEvents." + key;
                events.add(new TemperatureEventConfig(
                        key,
                        temperatureFile.getDouble(basePath + ".temperature", 0.0D),
                        temperatureFile.getString(basePath + ".mode", temperatureFile.getDouble(basePath + ".temperature", 0.0D) >= 0.0D ? "above" : "below"),
                        temperatureFile.getInt(basePath + ".priority", 0),
                        Math.round(temperatureFile.getDouble(basePath + ".cooldown-seconds", temperatureFile.getDouble("temperature-event-cooldown-seconds", 5.0D)) * 1000.0D),
                        temperatureFile.getStringList(basePath + ".effects")
                ));
            }
        }

        return new TemperatureConfig(
                seasonBaseTemperatures,
                "daily-random".equalsIgnoreCase(temperatureFile.getString("base-temperature.mode", "fixed")),
                seasonBaseRanges,
                temperatureFile.getBoolean("solar-term-modifier.enable", false),
                solarTermModifiers,
                temperatureFile.getDouble("biome-vanilla-scale", 5.0D),
                biomeOverrides,
                tropicalBiomes,
                conditionConfig,
                temperatureFile.getInt("display-decimals", 1),
                temperatureFile.getBoolean("action-bar.enable", true),
                temperatureFile.getLong("event-interval-ticks", 40L),
                temperatureFile.getBoolean("temperatureEventsEnabled", true),
                "highest-only".equalsIgnoreCase(temperatureFile.getString("temperature-event-mode", "highest-only")),
                Math.round(temperatureFile.getDouble("temperature-event-cooldown-seconds", 5.0D) * 1000.0D),
                temperatureFile.getDouble("body-temperature-step", 2.0D),
                temperatureFile.getDouble("water.wetness-recovery-per-step", temperatureFile.getDouble("wetness-recovery-per-step", 0.2D)),
                temperatureFile.getLong("water.wetness-recovery-interval-ticks", temperatureFile.getLong("wetness-recovery-interval-ticks", 40L)),
                armorWarmth,
                temperatureFile.getDouble("armor.leather-disabled-above", 25.0D),
                heldItemTemperatureModifiers,
                events
        );
    }

    private Map<Season, TemperatureRangeConfig> loadSeasonBaseRanges(FileConfiguration temperatureFile) {
        Map<Season, TemperatureRangeConfig> ranges = new EnumMap<>(Season.class);
        for (Season season : Season.values()) {
            String path = "base-temperature.season." + season.key();
            ranges.put(season, new TemperatureRangeConfig(
                    temperatureFile.getDouble(path + ".min", temperatureFile.getDouble("season-base-temperature." + season.key(), 18.0D)),
                    temperatureFile.getDouble(path + ".max", temperatureFile.getDouble("season-base-temperature." + season.key(), 18.0D))
            ));
        }
        return ranges;
    }

    private Map<String, Double> loadDoubleSection(FileConfiguration file, String path) {
        Map<String, Double> values = new LinkedHashMap<>();
        ConfigurationSection section = file.getConfigurationSection(path);
        if (section == null) {
            return values;
        }
        for (String key : section.getKeys(false)) {
            if (section.isConfigurationSection(key)) {
                continue;
            }
            values.put(key.toLowerCase(), section.getDouble(key));
        }
        return values;
    }

    private SeasonBiomeColorConfig loadBiomeColorConfig() {
        File file = new File(this.plugin.getDataFolder(), "season-color.yml");
        FileConfiguration colorFile = YamlConfiguration.loadConfiguration(file);

        boolean enabled = colorFile.getBoolean("enable", true);
        long intervalTicks = colorFile.getLong("interval-ticks", 60L);
        int radius = colorFile.getInt("radius", 8);

        Map<Season, Map<NamespacedKey, NamespacedKey>> allMappings = new EnumMap<>(Season.class);
        ConfigurationSection seasonsSection = colorFile.getConfigurationSection("seasons");
        if (seasonsSection != null) {
            for (String seasonKey : seasonsSection.getKeys(false)) {
                Season season = Season.fromKey(seasonKey).orElse(null);
                if (season == null) {
                    this.plugin.getLogger().warning("未知季节键名，跳过: " + seasonKey);
                    continue;
                }
                ConfigurationSection biomeSection = seasonsSection.getConfigurationSection(seasonKey);
                if (biomeSection == null) {
                    continue;
                }
                Map<NamespacedKey, NamespacedKey> mappings = new LinkedHashMap<>();
                for (String biomeKey : biomeSection.getKeys(false)) {
                    String targetKey = biomeSection.getString(biomeKey);
                    if (targetKey == null || targetKey.isBlank()) {
                        continue;
                    }
                    NamespacedKey original = parseNamespacedKey(biomeKey);
                    NamespacedKey target = parseNamespacedKey(targetKey);
                    if (original != null && target != null) {
                        mappings.put(original, target);
                    }
                }
                allMappings.put(season, Collections.unmodifiableMap(mappings));
            }
        }

        Map<Season, Map<NamespacedKey, BiomeVisualColors>> allVisuals = loadBiomeVisuals(colorFile);
        Map<Season, NamespacedKey> spoofTargets = new EnumMap<>(Season.class);
        ConfigurationSection spoofSeasonSection = colorFile.getConfigurationSection("biome-spoof.seasons");
        if (spoofSeasonSection != null) {
            for (String seasonKey : spoofSeasonSection.getKeys(false)) {
                Season season = Season.fromKey(normalizeSeasonKey(seasonKey)).orElse(null);
                NamespacedKey target = parseNamespacedKey(spoofSeasonSection.getString(seasonKey));
                if (season != null && target != null) {
                    spoofTargets.put(season, target);
                }
            }
        }
        putDefaultSpoofTargets(spoofTargets);
        return new SeasonBiomeColorConfig(
                enabled,
                intervalTicks,
                radius,
                allMappings,
                allVisuals,
                colorFile.getBoolean("biome-spoof.enable", true),
                colorFile.getInt("biome-spoof.radius-chunks", 8),
                colorFile.getInt("biome-spoof.budget-chunks-per-tick", 8),
                colorFile.getInt("biome-spoof.step-xz", 4),
                colorFile.getInt("biome-spoof.step-y", 4),
                spoofTargets
        );
    }

    private void putDefaultSpoofTargets(Map<Season, NamespacedKey> spoofTargets) {
        spoofTargets.putIfAbsent(Season.SPRING, NamespacedKey.minecraft("flower_forest"));
        spoofTargets.putIfAbsent(Season.SUMMER, NamespacedKey.minecraft("plains"));
        spoofTargets.putIfAbsent(Season.AUTUMN, NamespacedKey.minecraft("windswept_savanna"));
        spoofTargets.putIfAbsent(Season.WINTER, NamespacedKey.minecraft("snowy_plains"));
    }

    private Map<Season, Map<NamespacedKey, BiomeVisualColors>> loadBiomeVisuals(FileConfiguration colorFile) {
        Map<Season, Map<NamespacedKey, BiomeVisualColors>> allVisuals = new EnumMap<>(Season.class);
        ConfigurationSection groupsSection = colorFile.getConfigurationSection("biome-visuals");
        if (groupsSection == null) {
            return allVisuals;
        }

        for (String groupKey : groupsSection.getKeys(false)) {
            ConfigurationSection groupSection = groupsSection.getConfigurationSection(groupKey);
            if (groupSection == null) {
                continue;
            }
            List<NamespacedKey> biomes = groupSection.getStringList("biomes").stream()
                    .map(this::parseNamespacedKey)
                    .filter(java.util.Objects::nonNull)
                    .toList();
            ConfigurationSection seasonsSection = groupSection.getConfigurationSection("seasons");
            if (biomes.isEmpty() || seasonsSection == null) {
                continue;
            }
            for (String seasonKey : seasonsSection.getKeys(false)) {
                Season season = Season.fromKey(normalizeSeasonKey(seasonKey)).orElse(null);
                ConfigurationSection seasonSection = seasonsSection.getConfigurationSection(seasonKey);
                if (season == null || seasonSection == null) {
                    continue;
                }
                BiomeVisualColors colors = new BiomeVisualColors(
                        parseHexColor(seasonSection.getString("sky")),
                        parseHexColor(seasonSection.getString("water")),
                        parseHexColor(seasonSection.getString("waterFog")),
                        parseHexColor(seasonSection.getString("grass")),
                        parseHexColor(seasonSection.getString("tree")),
                        parseHexColor(seasonSection.getString("fog"))
                );
                if (!colors.hasAnyColor()) {
                    continue;
                }
                Map<NamespacedKey, BiomeVisualColors> seasonVisuals = allVisuals.computeIfAbsent(season, ignored -> new LinkedHashMap<>());
                for (NamespacedKey biome : biomes) {
                    seasonVisuals.put(biome, colors);
                }
            }
        }
        return allVisuals;
    }

    private String normalizeSeasonKey(String seasonKey) {
        return "fall".equalsIgnoreCase(seasonKey) ? "autumn" : seasonKey;
    }

    private Integer parseHexColor(String raw) {
        if (raw == null || raw.isBlank()) {
            return null;
        }
        String normalized = raw.trim();
        if (normalized.startsWith("#")) {
            normalized = normalized.substring(1);
        }
        if (normalized.length() != 6) {
            this.plugin.getLogger().warning("无法解析颜色配置: " + raw + "，请使用 6 位 HEX，例如 FFFFFF");
            return null;
        }
        try {
            return Integer.parseInt(normalized, 16);
        } catch (NumberFormatException ex) {
            this.plugin.getLogger().warning("无法解析颜色配置: " + raw + "，请使用 0-9 或 A-F");
            return null;
        }
    }

    private NamespacedKey parseNamespacedKey(String raw) {
        if (raw == null || raw.isBlank()) {
            return null;
        }
        String normalized = raw.toLowerCase(java.util.Locale.ROOT);
        return normalized.contains(":") ? NamespacedKey.fromString(normalized) : NamespacedKey.minecraft(normalized);
    }

    private MonthDay parseMonthDay(String raw, MonthDay fallback) {
        if (raw == null || raw.isBlank()) {
            return fallback;
        }

        try {
            String[] split = raw.split("-");
            if (split.length != 2) {
                return fallback;
            }
            int month = Integer.parseInt(split[0]);
            int day = Integer.parseInt(split[1]);
            return MonthDay.of(month, day);
        } catch (DateTimeParseException | IllegalArgumentException ex) {
            this.plugin.getLogger().warning("无法解析节气日期配置: " + raw + "，将使用默认值 " + fallback);
            return fallback;
        }
    }

    /**
     * 加载季节事件配置
     */
    private List<com.liseasons.event.SeasonEventConfig> loadSeasonEventConfigs() {
        File file = new File(this.plugin.getDataFolder(), "season-events.yml");
        FileConfiguration config = YamlConfiguration.loadConfiguration(file);
        return SeasonEventConfigLoader.loadSeasonEvents(config);
    }

    /**
     * 加载节日配置
     */
    private List<com.liseasons.festival.FestivalConfig> loadFestivalConfigs() {
        File file = new File(this.plugin.getDataFolder(), "festivals.yml");
        FileConfiguration config = YamlConfiguration.loadConfiguration(file);
        return FestivalConfigLoader.loadFestivals(config);
    }
}