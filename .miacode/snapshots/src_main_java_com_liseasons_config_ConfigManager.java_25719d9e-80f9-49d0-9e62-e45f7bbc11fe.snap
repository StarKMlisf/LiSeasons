        navigation.put("month-terms", loadGuiItem(guiFile, "calendar.navigation.month-terms", true, 50, Material.FILLED_MAP, Material.LODESTONE, null, null, "<green>本月节气</green>", List.of("<gray>查看本月节气安排。</gray>")));
        navigation.put("year-terms", loadGuiItem(guiFile, "calendar.navigation.year-terms", true, 51, Material.BOOKSHELF, Material.LODESTONE, null, null, "<gold>全年节气</gold>", List.of("<gray>查看全年二十四节气。</gray>")));
        navigation.put("temperature", loadGuiItem(guiFile, "calendar.navigation.temperature", true, 52, Material.CAMPFIRE, Material.LODESTONE, null, null, "<dark_red>农事温度</dark_red>", List.of("<gray>查看体感、空气温度和潮湿度。</gray>")));

        CalendarConfig.PaginationConfig pagination = new CalendarConfig.PaginationConfig(
