        categories.put("legal", loadGuiItem(guiFile, "calendar.festivals.categories.legal", true, 38, Material.GOLD_INGOT, null, null, null, "<gold>法定节日</gold>", List.of("<gray>法定/公共节日分类。</gray>")));
        categories.put("gregorian", loadGuiItem(guiFile, "calendar.festivals.categories.gregorian", true, 39, Material.DIAMOND, null, null, null, "<aqua>公历节日</aqua>", List.of("<gray>公历节日分类。</gray>")));
        categories.put("custom", loadGuiItem(guiFile, "calendar.festivals.categories.custom", true, 41, Material.NETHER_STAR, null, null, null, "<light_purple>自定义节日</light_purple>", List.of("<gray>服务器自定义节日分类。</gray>")));

