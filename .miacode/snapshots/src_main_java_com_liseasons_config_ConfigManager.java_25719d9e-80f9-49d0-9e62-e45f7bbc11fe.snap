                        loadGuiItem(guiFile, "calendar.season-events.item", true, -1, Material.FLOWERING_AZALEA, null, null, null, "<gold><event></gold>", List.of("<gray>季节：<white><season></white></gray>", "<gray>类型：<white><type></white></gray>", "<gray>介绍：<white><description></white></gray>", "<gray>触发：<white><trigger></white></gray>", "<gray>概率：<white><chance></white></gray>", "<gray>优先级：<white><priority></white></gray>", "<gray>冷却：<white><cooldown></white> 秒</gray>", "", "<gold>事件效果</gold>", "<gray>- <white><effects></white></gray>")),
                        loadGuiItem(guiFile, "calendar.season-events.guide", true, 40, Material.BOOK, null, null, null, "<gold>告示板说明</gold>", List.of("<gray>季节事件按当前季节自然触发。</gray>", "<gray>可在 season-events.yml 调整概率、冷却和效果。</gray>"))
                ),
                new CalendarConfig.FestivalsConfig(
                        loadGuiItem(guiFile, "calendar.festivals.title", true, 4, Material.CAKE, null, null, null, "<light_purple>节日纪念册</light_purple>", List.of("<gray>月份：<white><month></white></gray>", "<gray>节日数量：<white><count></white></gray>", "<gray>页码：<white><page></white></gray>")),
                        loadGuiItem(guiFile, "calendar.festivals.item", true, -1, Material.DIAMOND, Material.ENCHANTED_BOOK, null, null, "<light_purple><festival></light_purple>", List.of("<gray>日期：<white><date></white></gray>", "<gray>分类：<white><category></white></gray>", "<gray>介绍：<white><description></white></gray>", "<yellow><today></yellow>")),
                        categories,
                        loadGuiItem(guiFile, "calendar.festivals.guide", true, 40, Material.BOOK, null, null, null, "<gold>纪念册说明</gold>", List.of("<gray>节日列表来自 festivals.yml。</gray>", "<gray>可自定义启用、名称、日期与描述。</gray>"))
                )
