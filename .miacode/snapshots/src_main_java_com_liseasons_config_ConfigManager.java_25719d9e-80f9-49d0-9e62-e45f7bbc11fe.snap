        FileConfiguration guiFile = YamlConfiguration.loadConfiguration(file);
        String fallbackTitle = this.plugin.getConfig().getString("calendar.title", "<gradient:#6b4b2a:#4f6b3c>桃源季节手账</gradient>");
        int fallbackSize = this.plugin.getConfig().getInt("calendar.size", 54);

        Map<String, CalendarConfig.GuiItemConfig> navigation = new LinkedHashMap<>();
        navigation.put("season-events", loadGuiItem(guiFile, "calendar.navigation.season-events", true, 45, Material.BLAZE_ROD, Material.LODESTONE, null, null, "<gold>季节告示板</gold>", List.of("<gray>点击打开季节事件页。</gray>")));
