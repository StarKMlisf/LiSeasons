                loadGuiItem(guiFile, "calendar.pagination.next", true, 53, Material.SPECTRAL_ARROW, null, null, null, "<gold>下一页</gold>", List.of("<gray>翻到下一页。</gray>"))
        );

        Map<String, CalendarConfig.GuiItemConfig> overview = new LinkedHashMap<>();
        overview.put("season", loadGuiItem(guiFile, "calendar.overview.season", true, 4, Material.WRITABLE_BOOK, null, null, null, "<gold>农夫手账 · 今日</gold>", List.of("<gray>季节：<white><season></white></gray>", "<gray>日期：<white><date></white></gray>", "<gray>世界：<white><world></white></gray>")));
        overview.put("world", loadGuiItem(guiFile, "calendar.overview.world", true, 13, Material.MAP, null, null, null, "<green>农场地图</green>", List.of("<gray>当前世界：<white><world></white></gray>")));
        overview.put("month", loadGuiItem(guiFile, "calendar.overview.month", true, 20, Material.FLOWERING_AZALEA, null, null, null, "<green>本月田历</green>", List.of("<gray>月份：<white><month></white></gray>", "<gray>节气：<white><terms></white></gray>")));
        overview.put("term", loadGuiItem(guiFile, "calendar.overview.term", true, 21, Material.CLOCK, null, null, null, "<dark_green>节气刻度</dark_green>", List.of("<gray>当前节气：<white><term></white></gray>")));
        overview.put("temperature", loadGuiItem(guiFile, "calendar.overview.temperature", true, 22, Material.HONEYCOMB, null, Material.SNOWBALL, Material.BLAZE_POWDER, "<dark_red>体感温度</dark_red>", List.of("<gray>体感：<white><temperature></white></gray>", "<gray>空气：<white><air></white></gray>", "<gray>潮湿：<white><wetness></white></gray>")));
        overview.put("weather", loadGuiItem(guiFile, "calendar.overview.weather", true, 23, Material.WATER_BUCKET, null, null, null, "<dark_aqua>天气与环境</dark_aqua>", List.of("<gray><weather></gray>")));
