        contentSlots.put("year-terms", loadIntegerList(guiFile, "calendar.content-slots.year-terms", List.of(10, 11, 12, 13, 14, 15, 16, 19, 20, 21, 22, 23, 24, 25, 28, 29, 30, 31, 32, 33, 34, 37, 38, 39)));

