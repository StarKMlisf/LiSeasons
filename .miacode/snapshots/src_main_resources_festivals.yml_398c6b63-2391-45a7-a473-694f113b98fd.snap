# 服务器自定义节日 (9个)
# 默认日期仅作为模板，服主可以按服务器实际运营日程调整
server-custom-festivals:
  server-anniversary:
    type: "SERVER_ANNIVERSARY"
    date: "01-10"
    display-name: "服务器周年庆"
    category: "SERVER_CUSTOM"
    priority: 10
    enabled: true
    description: "纪念服务器开服周年，适合发放纪念奖励和举办全服活动"

  version-update-day:
    type: "VERSION_UPDATE_DAY"
    date: "02-10"
    display-name: "版本更新日"
    category: "SERVER_CUSTOM"
    priority: 8
    enabled: true
    description: "庆祝服务器版本更新，适合引导玩家体验新玩法"

  building-contest-day:
    type: "BUILDING_CONTEST_DAY"
    date: "03-20"
    display-name: "建筑比赛日"
    category: "SERVER_CUSTOM"
    priority: 8
    enabled: true
    description: "面向建筑玩家的主题比赛日，适合开放作品提交和评选"

  fishing-festival:
    type: "FISHING_FESTIVAL"
    date: "04-20"
    display-name: "钓鱼节"
    category: "SERVER_CUSTOM"
    priority: 7
    enabled: true
    description: "鼓励玩家参与钓鱼玩法，适合配置稀有鱼获或排行奖励"

  mining-festival:
    type: "MINING_FESTIVAL"
    date: "05-20"
    display-name: "挖矿节"
    category: "SERVER_CUSTOM"
    priority: 7
    enabled: true
    description: "围绕矿洞探索与资源采集的活动日"

  harvest-festival:
    type: "HARVEST_FESTIVAL"
    date: "09-22"
    display-name: "丰收节"
    category: "SERVER_CUSTOM"
    priority: 8
    enabled: true
    description: "秋季收获主题活动，适合农作物、料理和交易玩法"

  hunting-festival:
    type: "HUNTING_FESTIVAL"
    date: "10-18"
    display-name: "狩猎节"
    category: "SERVER_CUSTOM"
    priority: 7
    enabled: true
