    description: "春节前夜，象征旧年的结束和新年的开始"

# 法定节假日 (7个)
legal-holidays:
  new-year:
    type: "NEW_YEAR"
    date: "01-01"
    display-name: "元旦"
    category: "LEGAL_HOLIDAY"
    priority: 9
    enabled: true
    description: "新年的第一天，象征新的开始"

  spring-festival-holiday:
    type: "SPRING_FESTIVAL_HOLIDAY"
    date: "01-01"
    display-name: "春节假期"
    category: "LEGAL_HOLIDAY"
    priority: 10
    enabled: true
    description: "中国最长的假期，象征团圆与欢乐"

  qingming-holiday:
    type: "QINGMING_HOLIDAY"
    date: "04-05"
    display-name: "清明假期"
    category: "LEGAL_HOLIDAY"
    priority: 9
    enabled: true
