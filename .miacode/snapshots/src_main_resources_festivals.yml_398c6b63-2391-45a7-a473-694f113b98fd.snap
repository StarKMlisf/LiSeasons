# LISeasons 节日配置
# 定义 38 个节日及其相关信息
#
# 配置项说明：
# type: 节日类型，必须对应插件内置 FestivalType 枚举。
# date: 节日日期，格式为 MM-dd，取值范围 01-01 到 12-31。
# display-name: 节日展示名称，可使用中文。
# category: 节日分类，可选 TRADITIONAL、LEGAL_HOLIDAY、GREGORIAN、SERVER_CUSTOM。
# priority: 同一天存在多个节日时的优先级，数字越大越优先。
# enabled: 是否启用该节日，true 启用，false 禁用。
# description: 节日说明，会显示在节日菜单中。

# 全局设置
global:
  # 全局节日冷却时间（秒）
  festival-cooldown-seconds: 5
  # 是否启用节日系统
  enabled: true

# 中国传统节日 (13个)
traditional-festivals:
  spring-festival:
    type: "SPRING_FESTIVAL"
    date: "01-01"
    display-name: "春节"
    category: "TRADITIONAL"
    priority: 10
    enabled: true
    description: "中国最重要的传统节日，象征新的开始"

  lantern-festival:
    type: "LANTERN_FESTIVAL"
    date: "01-15"
    display-name: "元宵节"
    category: "TRADITIONAL"
    priority: 9
    enabled: true
    description: "春节后的第一个重要节日，象征团圆"

  dragon-boat-festival:
    type: "DRAGON_BOAT_FESTIVAL"
    date: "02-02"
    display-name: "龙抬头"
    category: "TRADITIONAL"
    priority: 8
    enabled: true
    description: "春季的重要节日，象征春天的到来"

  shangsi-festival:
    type: "SHANGSI_FESTIVAL"
    date: "03-03"
    display-name: "上巳节"
    category: "TRADITIONAL"
    priority: 7
    enabled: true
    description: "古代重要的节日，象征春天的生机"

  qingming-festival:
    type: "QINGMING_FESTIVAL"
    date: "04-05"
    display-name: "清明节"
    category: "TRADITIONAL"
    priority: 10
    enabled: true
    description: "祭祖扫墓的重要节日"

  dragon-boat-holiday:
    type: "DRAGON_BOAT_HOLIDAY"
    date: "05-05"
    display-name: "端午节"
    category: "TRADITIONAL"
    priority: 10
    enabled: true
    description: "夏季的重要节日，象征驱邪避灾"

  qixi-festival:
    type: "QIXI_FESTIVAL"
    date: "07-07"
    display-name: "七夕节"
    category: "TRADITIONAL"
    priority: 8
    enabled: true
    description: "中国的情人节，象征爱情与相聚"

  zhongyuan-festival:
    type: "ZHONGYUAN_FESTIVAL"
    date: "07-15"
    display-name: "中元节"
    category: "TRADITIONAL"
    priority: 7
    enabled: true
    description: "道教重要节日，象征祭祖"

  mid-autumn-festival:
    type: "MID_AUTUMN_FESTIVAL"
    date: "08-15"
    display-name: "中秋节"
    category: "TRADITIONAL"
    priority: 10
    enabled: true
    description: "秋季的重要节日，象征团圆与丰收"

  chongyang-festival:
    type: "CHONGYANG_FESTIVAL"
    date: "09-09"
    display-name: "重阳节"
    category: "TRADITIONAL"
    priority: 8
    enabled: true
    description: "秋季的重要节日，象征敬老与长寿"

  laba-festival:
    type: "LABA_FESTIVAL"
    date: "12-08"
    display-name: "腊八节"
    category: "TRADITIONAL"
    priority: 7
    enabled: true
    description: "冬季的重要节日，象征新年的开始"

  xiaonian:
    type: "XIAONIAN"
    date: "12-23"
    display-name: "小年"
    category: "TRADITIONAL"
    priority: 8
    enabled: true
    description: "春节前的重要节日，象征新年的临近"

  chuxi:
    type: "CHUXI"
    date: "12-30"
    display-name: "除夕"
    category: "TRADITIONAL"
