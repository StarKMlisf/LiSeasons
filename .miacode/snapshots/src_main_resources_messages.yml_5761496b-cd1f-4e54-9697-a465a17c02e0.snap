# LISeasons 消息配置
# 所有文本支持 MiniMessage。可用占位符会由代码按上下文替换，例如 <world>、<season>、<term>。
prefix: "<gradient:#7fd37f:#f7c873>[LISeasons]</gradient> "

season-names:
  spring: "春季"
  summer: "夏季"
  autumn: "秋季"
  winter: "冬季"

solar-term-names:
  lichun: "立春"
  yushui: "雨水"
  jingzhe: "惊蛰"
  chunfen: "春分"
  qingming: "清明"
  guyu: "谷雨"
  lixia: "立夏"
  xiaoman: "小满"
  mangzhong: "芒种"
  xiazhi: "夏至"
  xiaoshu: "小暑"
  dashu: "大暑"
  liqiu: "立秋"
  chushu: "处暑"
  bailu: "白露"
  qiufen: "秋分"
  hanlu: "寒露"
  shuangjiang: "霜降"
  lidong: "立冬"
  xiaoxue: "小雪"
  daxue: "大雪"
  dongzhi: "冬至"
  xiaohan: "小寒"
  dahan: "大寒"

command:
  no-permission: "<red>你没有权限使用这个指令。</red>"
  player-only: "<yellow>这个指令只能由玩家执行。</yellow>"
  reloaded: "<green>配置已重新加载。</green>"
  unknown-world: "<red>找不到这个世界。</red>"
  world-disabled: "<yellow>这个世界没有启用季节系统。</yellow>"
  unknown-season: "<red>未知季节，请输入 spring、summer、autumn 或 winter。</red>"
  unknown-term: "<red>未知节气，请输入有效的节气英文键名。</red>"
  set-season: "<green>已将世界 <white><world></white> 切换到 <white><season></white>。</green>"
  set-term: "<green>已将世界 <white><world></white> 切换到 <white><term></white>。</green>"
  set-auto: "<green>世界 <white><world></white> 已恢复自动轮转。</green>"
  advanced: "<green>世界 <white><world></white> 已前进到 <white><term></white>。</green>"
  info: "<green>世界 <white><world></white></green> 当前为 <white><season></white> | <white><term></white> <gray>(<mode>)</gray>"
  info-temperature: "<aqua>体感温度 <white><temperature></white>，状态：<white><weather></white></aqua>"
  calendar-opened: "<green>已打开四季日历。</green>"
  color-refresh: "<yellow>季节色调正在分批刷新，附近区块会逐步改变草地和树叶颜色。</yellow>"
  help:
    - "<yellow>/seasons info [世界]</yellow> <gray>- 查看当前季节、节气和温度</gray>"
    - "<yellow>/seasons calendar</yellow> <gray>- 打开四季日历菜单</gray>"
    - "<yellow>/seasons reload</yellow> <gray>- 重载配置</gray>"
    - "<yellow>/seasons set season <世界> <季节></yellow> <gray>- 手动切换季节</gray>"
    - "<yellow>/seasons set term <世界> <节气></yellow> <gray>- 手动切换节气</gray>"
    - "<yellow>/seasons next <世界></yellow> <gray>- 前进到下一个节气</gray>"
    - "<yellow>/seasons auto <世界></yellow> <gray>- 恢复自动轮转</gray>"

notify:
  join: "<green>当前节气是 <white><term></white>，正值 <white><season></white>。</green>"
  changed: "<green><world></green> 已进入 <white><season></white> | <white><term></white>"
  temperature-change: "<aqua>体感变化：</aqua><white><description></white><gray>，当前 </gray><aqua><temperature></aqua>"
  temperature-event: "<aqua>体感温度：</aqua><aqua><temperature></aqua><gray>，状态 </gray><white><description></white>"

hud:
  temperature: "<aqua>体感：</aqua><white><temperature></white>"

calendar:
  title: "<gradient:#7fd37f:#f7c873>LISeasons 四季日历</gradient>"
  season-item: "<green>当前季节</green>"
  term-item: "<green>当前节气</green>"
  temperature-item: "<aqua>体感温度</aqua>"
  temperature-base-item: "<aqua>季节基础温度</aqua>"
  temperature-weather-item: "<aqua>天气与环境</aqua>"
  temperature-guide-item: "<yellow>温度规则</yellow>"
  temperature-note-item: "<yellow>节气提醒</yellow>"
  status-item: "<green>当前状态</green>"
  world-item: "<green>所在世界</green>"
  weather-item: "<aqua>天气倾向</aqua>"
  next-item: "<yellow>下一个节气</yellow>"
  visual-item: "<green>自然变化</green>"
  month-item: "<yellow>本月节气</yellow>"
  month-summary-item: "<yellow>本月概览</yellow>"
  month-term-item: "<green><term></green>"
  year-term-item: "<green><term></green>"
  page-overview: "<green>总览</green>"
  page-month: "<yellow>本月</yellow>"
  page-year: "<yellow>全年</yellow>"
  page-temperature: "<aqua>温度</aqua>"
  page-close: "<red>关闭</red>"
  lore-season:
    - "<gray>世界会随季节逐步改变天气、群系色调和自然效果。</gray>"
    - "<white><season></white>"
  lore-term:
    - "<gray>二十四节气决定当前季节阶段。</gray>"
    - "<white><term></white>"
  lore-temperature:
    - "<gray>由季节、群系、昼夜、雨水、水体和热源综合计算。</gray>"
    - "<white><temperature></white>"
    - "<gray>空气温度：<white><air></white> | 潮湿：<white><wetness></white></gray>"
  lore-world:
    - "<gray>当前菜单对应的世界。</gray>"
    - "<white><world></white>"
  lore-weather:
    - "<gray>这个季节更常见的天气表现。</gray>"
    - "<white><weather></white>"
  lore-next:
    - "<gray>下一次自然推进会来到这里。</gray>"
    - "<white><next></white>"
  lore-visual:
    - "<gray>草地、树叶、天空、水体、雪和落叶都会随季节变化。</gray>"
    - "<white><visual></white>"
  lore-month:
    - "<gray>本月包含的节气。</gray>"
    - "<white><month></white>"
    - "<gray><terms></gray>"
  lore-month-term:
    - "<gray>日期：<white><date></white></gray>"
    - "<gray>季节：<white><season></white></gray>"
    - "<white><current></white>"
  lore-month-summary:
    - "<gray>本月节气列表。</gray>"
    - "<white><month></white>"
    - "<gray><terms></gray>"
  lore-year-term:
    - "<gray>日期：<white><date></white></gray>"
    - "<gray>季节：<white><season></white></gray>"
    - "<white><current></white>"
  lore-temperature-base:
    - "<gray>季节先决定基础温度，再叠加环境修正。</gray>"
    - "<gray><season></gray>"
    - "<white><base></white>"
  lore-temperature-weather:
    - "<gray>夜晚、雨水、海拔、水体和热源都会影响体感。</gray>"
    - "<gray><world></gray>"
    - "<white><weather></white>"
  lore-temperature-guide:
    - "<gray>夏季白天在沙漠、恶地、丛林和热带草原更容易过热。</gray>"
    - "<gray>冬季接触水体会快速失温。</gray>"
    - "<gray>火、营火、岩浆和火把可以提供不同程度的回温。</gray>"
    - "<gray>盔甲会略微减少失温。</gray>"
  lore-temperature-note:
    - "<gray>季节会影响作物、天气、结冰、积雪和生物生成。</gray>"
    - "<white><term></white>"
  lore-page-overview:
    - "<gray>查看当前季节、节气、温度和自然变化。</gray>"
  lore-page-month:
    - "<gray>查看本月节气。</gray>"
  lore-page-year:
    - "<gray>查看全年二十四节气。</gray>"
  lore-page-temperature:
    - "<gray>查看体感温度规则。</gray>"
  lore-page-close:
    - "<gray>关闭菜单。</gray>"
  lore-status:
    - "<gray>当前页面：<white><page></white></gray>"
    - "<gray>体感：<white><temperature></white></gray>"
    - "<gray>潮湿：<white><wetness></white></gray>"

  # 季节事件页面
  page-events: "<gold>季节事件</gold>"
  season-events-title: "<gold>季节事件系统</gold>"
  season-events-guide: "<yellow>事件说明</yellow>"
  event-item: "<yellow><event></yellow>"
  event-type: "<gray>类型：<white><type></white></gray>"
  event-trigger: "<gray>触发条件：<white><trigger></white></gray>"
  event-priority: "<gray>优先级：<white><priority></white></gray>"
  event-cooldown: "<gray>冷却时间：<white><cooldown></white> 秒</gray>"
  event-effects-title: "<gray>效果列表：</gray>"
  event-effect-item: "<gray>  - <white><effect></white></gray>"
  lore-page-events:
    - "<gray>查看当前季节的所有事件。</gray>"
  lore-season-events-title:
    - "<gray>当前季节：<white><season></white></gray>"
    - "<gray>事件数量：<white><count></white></gray>"
  lore-season-events-guide:
    - "<gray>季节事件会根据温度自动触发。</gray>"
    - "<gray>不同事件有不同的优先级和冷却时间。</gray>"
    - "<gray>事件效果包括粒子、药水、声音等。</gray>"
  
  # 节日页面
  page-festivals: "<light_purple>节日</light_purple>"
  festivals-title: "<light_purple>节日系统</light_purple>"
  festivals-guide: "<yellow>节日说明</yellow>"
  festivals-traditional: "<green>传统节日</green>"
  festivals-legal: "<gold>法定节假日</gold>"
  festivals-gregorian: "<aqua>公历节日</aqua>"
  festival-item: "<yellow><festival></yellow>"
  festival-date: "<gray>日期：<white><date></white></gray>"
  festival-category: "<gray>分类：<white><category></white></gray>"
  festival-today: "<gold>✨ 今日节日 ✨</gold>"
  lore-page-festivals:
    - "<gray>查看本月的所有节日。</gray>"
  lore-festivals-title:
    - "<gray>当前月份：<white><month></white></gray>"
    - "<gray>节日数量：<white><count></white></gray>"
  lore-festivals-traditional:
    - "<gray>查看所有传统节日。</gray>"
    - "<gray>包括春节、元宵节、端午节等。</gray>"
  lore-festivals-legal:
    - "<gray>查看所有法定节假日。</gray>"
    - "<gray>包括元旦、劳动节、国庆节等。</gray>"
  lore-festivals-gregorian:
    - "<gray>查看所有公历节日。</gray>"
    - "<gray>包括情人节、圣诞节等。</gray>"
  lore-festivals-guide:
    - "<gray>节日到来时会触发特殊事件。</gray>"
    - "<gray>点击分类按钮可以筛选节日。</gray>"
    - "<gray>今日节日会以附魔书显示。</gray>"
