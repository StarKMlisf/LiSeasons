    cooldown-seconds: 90
    chance-percent: 35
    enabled: true
    description: "大雪纷飞：地面积雪，水结冰，玩家移动减速。"
    effects:
      - "POTION:SLOWNESS:0:15"
      - "PARTICLE:SNOWFLAKE:32:1.0:0.8:1.0"
      - "MESSAGE:§f大雪纷飞，脚下的积雪让道路变得难行。"

  extreme-cold-night:
    type: "EXTREME_COLD_NIGHT"
    season: "WINTER"
    trigger-mode: "season"
    priority: 8
    cooldown-seconds: 120
    chance-percent: 25
    enabled: true
