    effects:
      - "DAMAGE:1.0"
      - "SCREEN_FREEZE:40"
      - "MESSAGE:§b极寒之夜降临，靠近火把才能稍稍回暖。"

  frost-morning-fog:
    type: "FROST_MORNING_FOG"
    season: "WINTER"
    trigger-mode: "season"
    priority: 7
    cooldown-seconds: 100
    chance-percent: 30
    enabled: true
    description: "冰霜晨雾：清晨生成雾气，视野距离降低，冰原怪物增强。"
    effects:
      - "PARTICLE:CLOUD:30:1.0:0.8:1.0"
